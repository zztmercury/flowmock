{
  "name": "whistle.pbmockx",
  "version": "0.4.0",
  "description": "Protobuf & JSON mock plugin for whistle — decode/patch/encode with field-tree viewer",
  "bin": {
    "pbmockx": "./bin/cli.js"
  },
  "scripts": {
    "dev": "tsc -w",
    "build": "tsc",
    "test": "tsc && node -e \"require('./dist/tests/test_pb-engine').run()\""
  },
  "dependencies": {
    "protobufjs": "^7.0.0",
    "long": "^5.2.0",
    "js-yaml": "^4.0.0",
    "koa": "^2.14.0",
    "@koa/router": "^13.0.0",
    "koa-bodyparser": "^4.4.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0",
    "@types/js-yaml": "^4.0.0",
    "@types/koa": "^2.14.0",
    "@types/koa__router": "^12.0.0"
  },
  "whistleConfig": {
    "inspectorsTab": {
      "req": {
        "name": "PBView",
        "action": "/public/pb-req.html"
      },
      "res": {
        "name": "PBView",
        "action": "/public/pb-res.html"
      }
    }
  }
}
