# pbmockx rules.yaml — runtime config (auto-generated, not tracked by git)
#
# Rule types:
#   patch:      url_pattern, path, value, protocol(pb|json)
#   map_local:  url_pattern, source(file|data), data_file|file_path, desc, messageType, delimited, status, headers
#   map_remote: url_pattern, replacement, is_regex
#
# Examples (uncomment to use):
#
# # Patch a PB field
# - id: aabbccdd
#   type: patch
#   url_pattern: 'api/person'
#   path: name
#   value: MockedName
#   protocol: pb
#
# # Map local with inline data (stored in mock-data/<id>.json)
# - id: eeff0011
#   type: map_local
#   url_pattern: 'api/game'
#   source: data
#   data_file: eeff0011.json
#   desc: 'http://example.com/Model.desc'
#   messageType: 'demo.Game'
#
# # Map local with file (whistle native rawfile://)
# - id: 22334455
#   type: map_local
#   url_pattern: 'api/data'
#   source: file
#   file_path: /abs/path/to/mock.pb
#
# # Map remote (whistle native https://)
# - id: 66778899
#   type: map_remote
#   url_pattern: 'api/old'
#   replacement: 'https://new.example.com/new'

